      "parameters": {
        "command": "=scp root@{{ $('Vast.ai: Create Instance (Job B)').item.json.public_ipaddr }}:/workspace/output_vi_horizontal.mp4 /tmp/output_vi_horizontal.mp4 && scp root@{{ $('Vast.ai: Create Instance (Job B)').item.json.public_ipaddr }}:/workspace/output_vi_vertical.mp4 /tmp/output_vi_vertical.mp4",
        "options": {}
      },
