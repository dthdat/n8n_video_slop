    {
      "parameters": {
        "jsCode": "// Parse output file paths from Job B\nconst output = $input.first().json.stdout || '';\nconst match = output.match(/===OUTPUT_FILES_START===\\n([\\s\\S]*?)\\n===OUTPUT_FILES_END===/);\n\nif (!match) {\n  throw new Error('Could not parse output files from Job B');\n}\n\nconst outputFiles = JSON.parse(match[1]);\nconst instanceId = $('Vast.ai: Create Instance (Job B)').item.json.new_contract;\n\nreturn [{\n  json: {\n    outputFiles: outputFiles,\n    instanceId: instanceId,\n    horizontalFile: outputFiles.find(f => f.includes('horizontal')),\n    verticalFile: outputFiles.find(f => f.includes('vertical')),\n  }\n}];"
      },
