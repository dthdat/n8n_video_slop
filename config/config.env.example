# ═══════════════════════════════════════════════════════════════
# Video Localization Pipeline — Configuration
# ═══════════════════════════════════════════════════════════════

# ── Vast.ai ──────────────────────────────────────────────────
VAST_API_KEY=your_vast_api_key_here
VAST_GPU_PREFERENCE=RTX_4060_Ti      # Fallbacks: RTX_3090, RTX_4070_Ti
VAST_DOCKER_IMAGE=your_dockerhub_user/video-localize:latest
VAST_DISK_GB=40

# ── Google Gemini ────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro

# ── TTS Provider (choose: "fpt" or "google") ────────────────
TTS_PROVIDER=google
# FPT.AI settings
FPT_API_KEY=your_fpt_api_key_here
FPT_VOICE=banmai
FPT_SPEED=0
# Google Cloud TTS settings
GOOGLE_TTS_API_KEY=your_google_cloud_api_key_here
GOOGLE_TTS_VOICE=vi-VN-Neural2-A
GOOGLE_TTS_SPEAKING_RATE=1.0

# ── Telegram ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Audio Processing ─────────────────────────────────────────
WHISPERX_MODEL=large-v3
WHISPERX_BATCH_SIZE=16
WHISPERX_COMPUTE_TYPE=float16
DEMUCS_MODEL=htdemucs_ft

# ── Synchronization ──────────────────────────────────────────
ATEMPO_MAX=1.15
BLEED_SECONDS=0.5

# ── Audio Mixing ─────────────────────────────────────────────
BGM_DUCK_THRESHOLD=0.05
BGM_DUCK_RATIO=10
BGM_DUCK_ATTACK=20
BGM_DUCK_RELEASE=300
BGM_BASE_VOLUME=0.3

# ── Subtitles ────────────────────────────────────────────────
SUBTITLE_FONT=Be Vietnam Pro
SUBTITLE_FONTSIZE=20
SUBTITLE_PRIMARY_COLOR=&H00FFFFFF
SUBTITLE_OUTLINE_COLOR=&H00000000
SUBTITLE_OUTLINE_WIDTH=3
SUBTITLE_BOX_COLOR=&H80000000

# ── Video Output ─────────────────────────────────────────────
NVENC_PRESET=p4
NVENC_CQ=25
OUTPUT_AUDIO_BITRATE=192k

# ── Render Modes (comma-separated: horizontal,vertical) ─────
RENDER_MODES=horizontal,vertical

# ── Visual Filter Bypass ─────────────────────────────────────
BRIGHTNESS_SHIFT=0.01
CONTRAST_SHIFT=1.01

# ── Avatar ───────────────────────────────────────────────────
AVATAR_ENABLED=true
AVATAR_IDLE=assets/avatar_idle.png
AVATAR_SPEAKING=assets/avatar_speaking.png
AVATAR_POSITION=bottom_right
AVATAR_SCALE=0.15
